; Engine configuration file.
; Godot 4.x project scaffold for WAGO. Open this folder in Godot after installing Godot 4.x.

config_version=5

[application]

config/name="WAGO"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
DialogueManager="*res://scripts/story/DialogueManager.gd"
StoryFlags="*res://scripts/story/StoryFlags.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[rendering]

textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
renderer/rendering_method="gl_compatibility"

